# Configuration variables for the system metrics service
INTERVAL=2 # Time in seconds
STORE_PREVIOUS=20 # Number of previous data points to store

# SQLite database configuration
SQLITE_DB_PATH="data.db" # Path to the SQLite database file
SQLITE_TABLE_NAME="" # Name of the table to store data points

# API endpoint to fetch data from
HOST="http://localhost:12345" # Base URL of the API server. IP address or container name can be used
API_ENDPOINT="${HOST}/usage" # URL of the API endpoint to fetch data from

# Metrics collection configuration
ENABLE_CPU_METRICS=true # Whether to enable CPU metrics collection
ENABLE_GPU_METRICS=true # Whether to enable GPU metrics collection
ENABLE_NPU_METRICS=false # Whether to enable NPU metrics collection
