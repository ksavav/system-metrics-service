# General settings
INTERVAL=10s

# Prometheus
PROMETHEUS_PORT=9090
# PROMETHEUS_URL=http://prometheus:${PROMETHEUS_PORT}
PROMETHEUS_URL=http://localhost:${PROMETHEUS_PORT}
PROMETHEUS_CONFIG_PATH=./configs/prometheus.yml

# OpenTelemetry
OTEL_COLLECTOR_PORT=4317
OTEL_COLLECTOR_API_PORT=8889
OTEL_COLLECTOR_URL=http://otel-collector:${OTEL_COLLECTOR_PORT}
OTEL_COLLECTOR_CONFIG_PATH=./configs/otel-collector-config.yaml

# Telegraf
TELEGRAF_CONFIG_PATH=./configs/telegraf.conf

# System Metrics Service
SYSTEM_METRICS_SERVICE_PORT=8000
SYSTEM_METRICS_SERVICE_URL=http://localhost:${SYSTEM_METRICS_SERVICE_PORT}
