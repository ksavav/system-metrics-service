# General settings
INTERVAL=5s

# Prometheus
PROMETHEUS_IMAGE_TAG=latest
PROMETHEUS_PORT=9090
# PROMETHEUS_URL=http://prometheus:${PROMETHEUS_PORT}
PROMETHEUS_URL=http://localhost:${PROMETHEUS_PORT}
PROMETHEUS_CONFIG_PATH=./configs/prometheus.yml

# OpenTelemetry
OTEL_IMAGE_TAG=latest
OTEL_PORT=4317
OTEL_API_PORT=8889
OTEL_URL=http://otel-collector:${OTEL_PORT}
OTEL_CONFIG_PATH=./configs/otel-collector-config.yaml

# Telegraf
TELEGRAF_IMAGE_TAG=latest
TELEGRAF_CONFIG_PATH=./configs/telegraf.conf

# System Metrics Service
SMS_IMAGE_TAG=latest
SMS_PORT=8000
SMS_URL=http://localhost:${SMS_PORT}
